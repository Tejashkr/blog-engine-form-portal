# n8n Form Trigger URL for "Weekly Blogs"
N8N_WEEKLY_BLOGS_URL=https://twothousandthirteen.app.n8n.cloud/form/53fa046f-cda4-4c1d-8d38-1a8d8fed1fa4

# Fallback URL if a form doesn't define its own n8nUrl
# N8N_FORM_URL=https://your-n8n-instance.com/form/your-form-path

# Portal access control (REQUIRED in production)
# Anyone without this password cannot view forms or submit to n8n.
PORTAL_ACCESS_PASSWORD=change-me-to-a-strong-password

# Optional: separate secret for signing session cookies (defaults to PORTAL_ACCESS_PASSWORD)
# AUTH_SECRET=generate-a-long-random-string

# Optional: if your n8n Form Trigger uses Basic Auth
# N8N_BASIC_AUTH_USER=
# N8N_BASIC_AUTH_PASSWORD=
